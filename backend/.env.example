# 应用配置
APP_NAME=自定义报表系统
APP_VERSION=1.0.0
DEBUG=True

# 数据库配置（元数据存储 - PostgreSQL）
DATABASE_URL=postgresql://user:pass@db:5432/reports

# 文件存储
EXPORT_DIR=./exports

# 邮件配置（根据实际 SMTP 服务填写）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=reports@example.com

# 安全密钥（生产环境请修改）
SECRET_KEY=your-secret-key-change-in-production
